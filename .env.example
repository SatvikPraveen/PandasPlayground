# ========================================
# 🔧 Environment Variables Template
# ========================================
# Copy this file to .env and customize as needed
# Note: .env is gitignored and should never be committed

# ----------------------------------------
# Streamlit Configuration
# ----------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_FILE_WATCHER_TYPE=auto

# ----------------------------------------
# Data Paths
# ----------------------------------------
DATA_PATH=exports/
RAW_DATA_PATH=data/
ASSETS_PATH=assets/
EXPORTS_PATH=exports/

# ----------------------------------------
# Jupyter Configuration
# ----------------------------------------
JUPYTER_PORT=8888
JUPYTER_TOKEN=
JUPYTER_ALLOW_ROOT=true

# ----------------------------------------
# Performance Settings
# ----------------------------------------
# Set pandas display options
PANDAS_MAX_ROWS=100
PANDAS_MAX_COLUMNS=50

# Memory limits (in MB)
MAX_MEMORY_MB=4096

# ----------------------------------------
# Development Settings
# ----------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# ----------------------------------------
# Optional: Database Configuration
# ----------------------------------------
# Uncomment if you add database integration
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pandasplayground
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# ----------------------------------------
# Optional: API Keys
# ----------------------------------------
# Uncomment if you add external data sources
# KAGGLE_USERNAME=
# KAGGLE_KEY=
# ALPHA_VANTAGE_API_KEY=
